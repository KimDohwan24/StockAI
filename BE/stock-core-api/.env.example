# Server
SERVER_PORT=8080

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/stock-ai
SPRING_DATASOURCE_USERNAME=your_username
SPRING_DATASOURCE_PASSWORD=your_password

# JPA
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# App Settings
APP_AI_SERVER_URL=http://localhost:8000
APP_AI_SERVER_TIMEOUT=5000
APP_JWT_SECRET=your_256bit_jwt_secret_here
APP_JWT_EXPIRATION=86400000

# KIS API
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_OAUTH_URL=https://openapi.koreainvestment.com:9443
KIS_APPKEY=your_kis_appkey
KIS_APPSECRET=your_kis_appsecret
KIS_ACCOUNT_CANO=your_account_number
KIS_ACCOUNT_ACNT_PRDT_CD=01
KIS_WEBSOCKET_URL=ws://ops.koreainvestment.com:21000
# KIS API 주문 전송 활성화 (true: KIS 실서버로 모의주문 전송, false: 로컬 가상 체결 모드)
KIS_MOCK_ORDER_ENABLED=false
